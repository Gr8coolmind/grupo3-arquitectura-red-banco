        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;graph TD\n    %% ==========================================\n    %% DIAGRAMA DE ARQUITECTURA DE RED SEGURA - BANCO\n    %% Actividad Academica - Grupo 3\n    %% ==========================================\n\n    subgraph PERIMETRO[\&quot;ZONA DE PERIMETRO EXTERNO\&quot;]\n        INET((\&quot;INTERNET&lt;br/&gt;Clientes / Publico General\&quot;))\n        VPN[/\&quot;Tunel VPN Site-to-Site&lt;br/&gt;Sucursales Remotas\&quot;/]\n    end\n\n    subgraph NUCLEO[\&quot;NUCLEO DE SEGURIDAD PERIMETRAL\&quot;]\n        FW{{\&quot;NGFW&lt;br/&gt;FIREWALL DE NUEVA GENERACION&lt;br/&gt;(Punto Unico de Inspeccion)\&quot;}}\n        IDS[[\&quot;IDS / IPS&lt;br/&gt;Sistema de Deteccion de Intrusos&lt;br/&gt;(Monitoreo - SPAN Port)\&quot;]]\n    end\n\n    subgraph DMZ[\&quot;ZONA DESMILITARIZADA (DMZ)\&quot;]\n        WEB((\&quot;Servidor Banca en Linea&lt;br/&gt;Plataforma Web Transaccional\&quot;))\n    end\n\n    subgraph OFICINAS[\&quot;RED INTERNA - OFICINAS ADMINISTRATIVAS\&quot;]\n        SW_OFI[/\&quot;Switch de Distribucion&lt;br/&gt;Oficinas\&quot;/]\n        PC_EMP((\&quot;PCs Empleados&lt;br/&gt;Operacion Diaria\&quot;))\n        PC_GER((\&quot;PCs Gerencia&lt;br/&gt;Acceso Administrativo\&quot;))\n    end\n\n    subgraph CRITICA[\&quot;RED CRITICA AISLADA - ALTA SEGURIDAD\&quot;]\n        SW_CORE[/\&quot;Switch Core&lt;br/&gt;Segmento Air-Gapped Logico\&quot;/]\n        DB[(\&quot;Datacenter&lt;br/&gt;Base de Datos Principal&lt;br/&gt;(Core Bancario)\&quot;)]\n        ATM((\&quot;Cajeros Automaticos&lt;br/&gt;Red ATM Dedicada\&quot;))\n    end\n\n    %% ==========================================\n    %% FLUJO DE CONEXIONES CON REGLAS DE FIREWALL\n    %% ==========================================\n\n    INET ==&gt;|\&quot;Permitir SOLO HTTPS&lt;br/&gt;Puerto 443 - Inspeccion SSL\&quot;| FW\n    VPN ==&gt;|\&quot;Trafico Cifrado IPSec&lt;br/&gt;Autenticacion Mutua\&quot;| FW\n\n    FW -.-&gt;|\&quot;Espejo de Trafico&lt;br/&gt;(Port Mirroring)\&quot;| IDS\n    IDS -.-&gt;|\&quot;Alertas en Tiempo Real&lt;br/&gt;Bloqueo Automatico\&quot;| FW\n\n    FW ==&gt;|\&quot;Permitir SOLO HTTPS&lt;br/&gt;Denegar todo lo demas\&quot;| WEB\n\n    FW ==&gt;|\&quot;Salida a Internet Filtrada&lt;br/&gt;Proxy Web / Control de Contenido\&quot;| SW_OFI\n    SW_OFI --&gt; PC_EMP\n    SW_OFI --&gt; PC_GER\n\n    FW ==&gt;|\&quot;BLOQUEO TOTAL desde Oficinas&lt;br/&gt;Sin excepcion directa\&quot;| SW_CORE\n\n    WEB -.-&gt;|\&quot;Consulta Autorizada y Auditada&lt;br/&gt;Puerto 1433/3306 - Solo Lectura\&quot;| SW_CORE\n\n    SW_CORE --&gt; DB\n    SW_CORE ==&gt;|\&quot;Protocolo Cifrado Propietario&lt;br/&gt;Canal Dedicado ATM\&quot;| ATM\n\n    %% ==========================================\n    %% ESTILOS PROFESIONALES (classDef)\n    %% ==========================================\n\n    classDef perimetro fill:#37474f,stroke:#1c262b,stroke-width:2px,color:#ffffff,font-weight:bold,rx:8,ry:8\n    classDef nucleo fill:#4a148c,stroke:#1a0033,stroke-width:3px,color:#ffffff,font-weight:bold,rx:8,ry:8\n    classDef dmz fill:#ff9800,stroke:#e65100,stroke-width:2px,color:#1a1a1a,font-weight:bold,rx:8,ry:8\n    classDef oficinas fill:#1565c0,stroke:#0d47a1,stroke-width:2px,color:#ffffff,font-weight:bold,rx:8,ry:8\n    classDef critica fill:#8b0000,stroke:#4a0000,stroke-width:3px,color:#ffffff,font-weight:bold,rx:8,ry:8\n\n    class INET,VPN perimetro\n    class FW,IDS nucleo\n    class WEB dmz\n    class SW_OFI,PC_EMP,PC_GER oficinas\n    class SW_CORE,DB,ATM critica\n\n    style PERIMETRO fill:#eceff1,stroke:#455a64,stroke-width:2px\n    style NUCLEO fill:#ede7f6,stroke:#4a148c,stroke-width:2px\n    style DMZ fill:#fff3e0,stroke:#e65100,stroke-width:2px\n    style OFICINAS fill:#e3f2fd,stroke:#0d47a1,stroke-width:2px\n    style CRITICA fill:#ffebee,stroke:#8b0000,stroke-width:3px&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="mV-ksIXwEmNgvF4IsC9P-28">
          <mxCell connectable="0" parent="1" style="group;transparentBounds=1;editIcon=1;lockedGroup=0;groupPadding=20;" vertex="1">
